{
  "name": "@sequentialos/zellous",
  "version": "2.0.0",
  "description": "Real-time collaboration and communication library with PTT, rooms, and file sharing",
  "type": "module",
  "main": "lib/index.js",
  "exports": {
    ".": "./lib/index.js",
    "./client": "./lib/index.js",
    "./core": "./lib/zellous-core.js",
    "./handlers": "./lib/default-handlers.js",
    "./handlers/media": "./lib/handlers-media.js",
    "./handlers/messaging": "./lib/handlers-messaging.js",
    "./storage": "./lib/storage-adapter.js",
    "./server": "./server.js",
    "./db": "./server/db.js",
    "./auth": "./server/auth-ops.js",
    "./config": "./server/config.js",
    "./errors": "./server/errors.js",
    "./middleware": "./server/middleware.js",
    "./event-bus": "./server/event-bus.js",
    "./plugins": "./server/plugin-loader.js"
  },
  "files": [
    "lib/",
    "server/",
    "server.js",
    "plugins/example.js",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon",
    "lib": "node lib/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "collaboration",
    "real-time",
    "websocket",
    "ptt",
    "push-to-talk",
    "rooms",
    "sessions",
    "file-sharing",
    "audio",
    "video"
  ],
  "dependencies": {
    "@sequentialos/sequential-logging": "^1.0.0",
    "busybase": "file:../busybase",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "livekit-server-sdk": "^2.15.0",
    "msgpackr": "^1.11.5",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AnEntrypoint/zellous"
  }
}
